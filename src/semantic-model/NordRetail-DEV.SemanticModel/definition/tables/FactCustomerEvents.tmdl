table FactCustomerEvents
	lineageTag: d6829d51-74dc-4095-a959-e40e8864f05f

	/// Nombre de clients ayant effectué au moins un achat
	measure 'Active Customers' = DISTINCTCOUNT(FactSales[CustomerKey])
		formatString: 0
		displayFolder: 03-Customer
		lineageTag: 17204ee8-a368-4d08-afb9-66d344b06f5a

	measure 'Repeat Customers' = CALCULATE(DISTINCTCOUNT(FactCustomerEvents[CustomerKey]), FactCustomerEvents[EventType] = "Repeat")
		formatString: 0
		displayFolder: 03-Customer
		lineageTag: d87cb80c-cb99-4a58-b6e1-6b010530edbc

	/// Taux de rétention des clients
	measure 'Customer Retention Rate'
		displayFolder: 03-Customer
		lineageTag: 8792c620-e5ef-46ea-aada-7b91152da34a

	measure 'Average LTV' = AVERAGE(FactCustomerEvents[LTV])
		formatString: 0
		lineageTag: d959c0ef-e702-42e6-8cfa-3b2514aff480

	measure Churn = CALCULATE(DISTINCTCOUNT(FactCustomerEvents[CustomerKey]), FactCustomerEvents[EventType] = "Churn")
		formatString: 0
		lineageTag: 67db7e86-3cfb-4636-81d3-401685829179

